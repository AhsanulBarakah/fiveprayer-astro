---
import { fetchPrayerTimes, type PrayerTimesResponse } from '../lib/api';
---

<div class="prayer-times-container">
  <p class="loading" id="loading">Loading prayer times...</p>

  <div class="error-container" id="error-container" style="display: none;">
    <div class="error-icon">⚠️</div>
    <h3 class="error-title">Unable to Load Prayer Times</h3>
    <p class="error-message" id="error-message"></p>
    <p class="error-hint">Please check your API key configuration and try again.</p>
  </div>

  <div class="prayer-times" id="prayer-times" style="display: none;" data-prayer-data="">
    <div class="language-switcher">
      <label>
        <input type="radio" name="language" value="en" checked />
        <span>English</span>
      </label>
      <label>
        <input type="radio" name="language" value="ar" />
        <span>العربية</span>
      </label>
    </div>

    <div class="header">
      <h1 data-key="title">Prayer Times</h1>
      <p class="date" data-key="date"></p>
      <p class="current-time">
        <span data-key="current_time_label"></span>: <span id="live-clock"></span>
      </p>
    </div>

    <div class="next-prayer">
      <span class="next-prayer-icon" id="next-prayer-icon">🌙</span>
      <h2 data-key="next_prayer_label"></h2>
      <div class="next-prayer-info">
        <div class="next-prayer-details">
          <span class="prayer-name" data-key="next_prayer"></span>
          <span class="prayer-time" data-key="next_time"></span>
        </div>
      </div>
    </div>

    <div class="prayer-schedule">
      <h3 data-key="schedule_label">Today's Schedule</h3>
      
      <div class="prayer-row" data-prayer="fajr">
        <span class="prayer-icon">🌙</span>
        <span class="prayer-name" data-key="fajr_name"></span>
        <span class="prayer-time">
          <span data-key="fajr_begins"></span>
          <span class="iqamah"><span data-key="iqamah_label"></span>: <span data-key="fajr_iqamah"></span></span>
        </span>
      </div>

      <div class="prayer-row sunrise" data-prayer="sunrise">
        <span class="prayer-icon">🌅</span>
        <span class="prayer-name" data-key="sunrise_name"></span>
        <span class="prayer-time" data-key="sunrise_time"></span>
      </div>

      <div class="prayer-row" data-prayer="dhuhr">
        <span class="prayer-icon">☀️</span>
        <span class="prayer-name" data-key="dhuhr_name"></span>
        <span class="prayer-time">
          <span data-key="dhuhr_begins"></span>
          <span class="iqamah"><span data-key="iqamah_label"></span>: <span data-key="dhuhr_iqamah"></span></span>
        </span>
      </div>

      <div class="prayer-row" data-prayer="asr">
        <span class="prayer-icon">🌤️</span>
        <span class="prayer-name" data-key="asr_name"></span>
        <span class="prayer-time">
          <span data-key="asr_begins"></span>
          <span class="iqamah"><span data-key="iqamah_label"></span>: <span data-key="asr_iqamah"></span></span>
        </span>
      </div>

      <div class="prayer-row" data-prayer="maghrib">
        <span class="prayer-icon">🌇</span>
        <span class="prayer-name" data-key="maghrib_name"></span>
        <span class="prayer-time">
          <span data-key="maghrib_begins"></span>
          <span class="iqamah"><span data-key="iqamah_label"></span>: <span data-key="maghrib_iqamah"></span></span>
        </span>
      </div>

      <div class="prayer-row" data-prayer="isha">
        <span class="prayer-icon">🌃</span>
        <span class="prayer-name" data-key="isha_name"></span>
        <span class="prayer-time">
          <span data-key="isha_begins"></span>
          <span class="iqamah"><span data-key="iqamah_label"></span>: <span data-key="isha_iqamah"></span></span>
        </span>
      </div>
    </div>

    <p class="timezone" id="timezone"></p>
    <p class="disclaimer">Please follow your local masjid prayer times. Data provided by fiveprayer API, built with Astro.</p>
  </div>
</div>

<style>
  .prayer-times-container {
    max-width: 500px;
    margin: 0 auto;
    padding: 0.5rem;
    font-family: system-ui, -apple-system, sans-serif;
  }

  .loading {
    text-align: center;
    padding: 2rem;
    font-size: 1.1rem;
    color: #666;
  }

  .error-container {
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 15px;
    padding: 2rem;
    text-align: center;
    box-shadow: 0 4px 15px rgba(220, 38, 38, 0.1);
  }

  .error-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .error-title {
    margin: 0 0 0.75rem 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: #dc2626;
  }

  .error-message {
    margin: 0 0 0.5rem 0;
    font-size: 0.95rem;
    color: #991b1b;
  }

  .error-hint {
    margin: 0;
    font-size: 0.85rem;
    color: #7f1d1d;
  }

  .prayer-times {
    background: white;
    border-radius: 15px;
    padding: 0.75rem;
    color: #1a1a1a;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
    border: 1px solid #e5e5e5;
  }

  .language-switcher {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    width: 100%;
  }

  .language-switcher label {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    cursor: pointer;
    font-size: 0.85rem;
    padding: 0.25rem 0.75rem;
    background: #f5f5f5;
    border-radius: 15px;
    transition: background 0.2s;
    color: #1a1a1a;
    width: 100px;
    justify-content: center;
  }

  .language-switcher label:hover {
    background: #e5e5e5;
  }

  .language-switcher input[type="radio"] {
    cursor: pointer;
    accent-color: #10b981;
    margin: 0;
  }

  .header {
    text-align: center;
    margin-bottom: 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #e5e5e5;
  }

  .header h1 {
    margin: 0 0 0.125rem 0;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .date {
    margin: 0.125rem 0 0.75rem 0;
    font-size: 0.9rem;
    color: #666;
  }

  .current-time {
    margin: 0;
    font-size: 0.8rem;
    color: #888;
  }

  .current-time span {
    margin-left: -0.5rem;
  }

  #live-clock {
    font-family: 'Courier New', Courier, monospace;
    display: inline-block;
    min-width: 120px;
  }

  .next-prayer {
    background: linear-gradient(294deg, #308d07 0%, #299f02 100%);
    border-radius: 10px;
    padding: 0.75rem;
    margin-bottom: 0.75rem;
    text-align: center;
    color: white;
    position: relative;
  }

  .next-prayer-icon {
    position: absolute;
    top: 0;
    right: 0.5rem;
    font-size: 1.25rem;
  }

  .next-prayer h2 {
    margin: 0 0 0.25rem 0;
    font-size: 0.75rem;
    opacity: 0.9;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .next-prayer-info {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
  }

  .next-prayer .prayer-name {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .next-prayer .prayer-time {
    font-size: 1.1rem;
    font-weight: 600;
  }

  .prayer-schedule h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1rem;
    color: #1a1a1a;
  }

  .prayer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem;
    background: #f9f9f9;
    border-radius: 8px;
    margin-bottom: 0.375rem;
    transition: all 0.2s;
    gap: 0.375rem;
  }

  .prayer-row:hover {
    background: #f0f0f0;
  }

  .prayer-row.sunrise {
    opacity: 0.7;
  }

  .prayer-row.next-prayer-highlight {
    background: linear-gradient(135deg, #10b94d 0%, #586500 100%);
    color: white;
    transform: scale(1.02);
    box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
  }

  .prayer-row.next-prayer-highlight .prayer-name,
  .prayer-row.next-prayer-highlight .prayer-time,
  .prayer-row.next-prayer-highlight .iqamah {
    color: white;
  }

  .prayer-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .next-prayer-icon {
    font-size: 3rem;
  }

  .next-prayer-details {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .prayer-row .prayer-name {
    font-weight: 600;
    font-size: 0.9rem;
    flex: 1;
  }

  .prayer-row .prayer-time {
    font-weight: 500;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.125rem;
    color: #666;
  }

  .iqamah {
    font-size: 0.75rem;
    color: #888;
  }

  .timezone {
    text-align: center;
    margin-top: 0.5rem;
    font-size: 0.7rem;
    color: #888;
  }

  .disclaimer {
    text-align: center;
    margin-top: 0.5rem;
    font-size: 0.65rem;
    color: #999;
    line-height: 1.4;
  }

  @media (max-width: 640px) {
    .prayer-times-container {
      padding: 1rem;
    }

    .prayer-times {
      padding: 1.5rem;
    }

    .header h1 {
      font-size: 1.5rem;
    }

    .next-prayer .prayer-name,
    .next-prayer .prayer-time {
      font-size: 1.4rem;
    }

    .prayer-row {
      padding: 0.75rem;
    }
  }
</style>

<script>
  let currentLang = 'en';
  let prayerData: any = null;

  async function fetchPrayerTimesData() {
    try {
      const response = await fetch('/api/prayer-times');
      if (!response.ok) throw new Error('Failed to fetch prayer times');
      const data = await response.json();
      prayerData = data;
      displayPrayerTimes(data);
      return data;
    } catch (error) {
      showError(error instanceof Error ? error.message : 'Failed to load prayer times');
      return null;
    }
  }

  function displayPrayerTimes(data: any) {
    const loadingEl = document.getElementById('loading');
    const errorContainer = document.getElementById('error-container');
    const prayerTimesDiv = document.getElementById('prayer-times') as HTMLElement;

    if (loadingEl) loadingEl.style.display = 'none';
    if (errorContainer) errorContainer.style.display = 'none';
    if (prayerTimesDiv) {
      prayerTimesDiv.style.display = 'block';
      prayerTimesDiv.dataset.prayerData = JSON.stringify(data);
    }

    // Update all data-key elements
    const elements = document.querySelectorAll('[data-key]');
    elements.forEach(el => {
      const key = el.dataset.key;
      let value = '';

      switch (key) {
        case 'title':
          value = 'Prayer Times';
          break;
        case 'date':
          value = data.date_translated?.en || '';
          break;
        case 'current_time_label':
          value = data.current_local_time_label?.en || '';
          break;
        case 'next_prayer_label':
          value = data.next_prayer_label?.en || '';
          break;
        case 'next_prayer':
          value = data.next_prayer?.en || '';
          break;
        case 'next_time':
          value = data.next_time?.en || '';
          break;
        case 'schedule_label':
          value = "Today's Schedule";
          break;
        case 'fajr_name':
          value = data.prayer_schedule?.fajr?.name?.en || '';
          break;
        case 'fajr_begins':
          value = data.prayer_schedule?.fajr?.begins?.en || '';
          break;
        case 'iqamah_label':
          value = data.iqamah_label?.en || '';
          break;
        case 'fajr_iqamah':
          value = data.prayer_schedule?.fajr?.iqamah?.en || '';
          break;
        case 'sunrise_name':
          value = data.prayer_schedule?.sunrise?.name?.en || '';
          break;
        case 'sunrise_time':
          value = data.prayer_schedule?.sunrise?.time?.en || '';
          break;
        case 'dhuhr_name':
          value = data.prayer_schedule?.dhuhr?.name?.en || '';
          break;
        case 'dhuhr_begins':
          value = data.prayer_schedule?.dhuhr?.begins?.en || '';
          break;
        case 'dhuhr_iqamah':
          value = data.prayer_schedule?.dhuhr?.iqamah?.en || '';
          break;
        case 'asr_name':
          value = data.prayer_schedule?.asr?.name?.en || '';
          break;
        case 'asr_begins':
          value = data.prayer_schedule?.asr?.begins?.en || '';
          break;
        case 'asr_iqamah':
          value = data.prayer_schedule?.asr?.iqamah?.en || '';
          break;
        case 'maghrib_name':
          value = data.prayer_schedule?.maghrib?.name?.en || '';
          break;
        case 'maghrib_begins':
          value = data.prayer_schedule?.maghrib?.begins?.en || '';
          break;
        case 'maghrib_iqamah':
          value = data.prayer_schedule?.maghrib?.iqamah?.en || '';
          break;
        case 'isha_name':
          value = data.prayer_schedule?.isha?.name?.en || '';
          break;
        case 'isha_begins':
          value = data.prayer_schedule?.isha?.begins?.en || '';
          break;
        case 'isha_iqamah':
          value = data.prayer_schedule?.isha?.iqamah?.en || '';
          break;
      }

      if (value) {
        el.textContent = value;
      }
    });

    // Update timezone
    const timezoneEl = document.getElementById('timezone');
    if (timezoneEl) {
      timezoneEl.textContent = `Timezone: ${data.timezone || ''}`;
    }

    updateNextPrayerIcon();
  }

  function showError(message: string) {
    const loadingEl = document.getElementById('loading');
    const errorContainer = document.getElementById('error-container');
    const errorMessageEl = document.getElementById('error-message');
    const prayerTimesDiv = document.getElementById('prayer-times');

    if (loadingEl) loadingEl.style.display = 'none';
    if (errorContainer) errorContainer.style.display = 'block';
    if (errorMessageEl) errorMessageEl.textContent = message;
    if (prayerTimesDiv) prayerTimesDiv.style.display = 'none';
  }

  function updateClock() {
    const clockElement = document.getElementById('live-clock');
    if (clockElement) {
      const now = new Date();
      const hours = now.getHours();
      const minutes = now.getMinutes().toString().padStart(2, '0');
      const seconds = now.getSeconds().toString().padStart(2, '0');
      const ampm = hours >= 12 ? 'PM' : 'AM';
      const displayHours = hours % 12 || 12;
      
      if (currentLang === 'ar') {
        const toArabicNumeral = (n: string) => {
          const arabicNumerals = ['٠', '١', '٢', '٣', '٤', '٥', '٦', '٧', '٨', '٩'];
          return n.replace(/\d/g, (d) => arabicNumerals[parseInt(d)]);
        };
        const arabicAmpm = hours >= 12 ? 'م' : 'ص';
        clockElement.textContent = `${toArabicNumeral(displayHours.toString())}:${toArabicNumeral(minutes)}:${toArabicNumeral(seconds)} ${arabicAmpm}`;
      } else {
        clockElement.textContent = `${displayHours}:${minutes}:${seconds} ${ampm}`;
      }
    }
  }

  function parseTime(timeStr: string): number {
    const [hours, minutes] = timeStr.split(':').map(Number);
    return hours * 60 + minutes;
  }

  function getNextPrayer(data: any): { name: string; time: string; icon: string } | null {
    const now = new Date();
    const currentMinutes = now.getHours() * 60 + now.getMinutes();
    
    const prayers = [
      { name: 'fajr', time: data.prayer_schedule?.fajr?.begins?.en, icon: '🌙' },
      { name: 'sunrise', time: data.prayer_schedule?.sunrise?.time?.en, icon: '🌅' },
      { name: 'dhuhr', time: data.prayer_schedule?.dhuhr?.begins?.en, icon: '☀️' },
      { name: 'asr', time: data.prayer_schedule?.asr?.begins?.en, icon: '🌤️' },
      { name: 'maghrib', time: data.prayer_schedule?.maghrib?.begins?.en, icon: '🌇' },
      { name: 'isha', time: data.prayer_schedule?.isha?.begins?.en, icon: '🌃' }
    ];

    for (const prayer of prayers) {
      if (prayer.time) {
        const prayerMinutes = parseTime(prayer.time);
        if (prayerMinutes > currentMinutes) {
          return prayer;
        }
      }
    }

    return prayers[0];
  }

  function updateNextPrayerIcon() {
    if (!prayerData) return;

    const nextPrayer = getNextPrayer(prayerData);
    if (!nextPrayer) return;

    const nextPrayerIcon = document.getElementById('next-prayer-icon');
    if (nextPrayerIcon) {
      nextPrayerIcon.textContent = nextPrayer.icon;
    }

    const nextPrayerNameEl = document.querySelector('[data-key="next_prayer"]');
    const nextPrayerTimeEl = document.querySelector('[data-key="next_time"]');
    
    if (nextPrayerNameEl) {
      nextPrayerNameEl.textContent = prayerData.prayer_schedule?.[nextPrayer.name]?.name?.en || nextPrayer.name;
    }
    
    if (nextPrayerTimeEl) {
      nextPrayerTimeEl.textContent = nextPrayer.time;
    }

    document.querySelectorAll('.prayer-row').forEach(row => {
      row.classList.remove('next-prayer-highlight');
    });

    const prayerRows = document.querySelectorAll('.prayer-row[data-prayer]');
    prayerRows.forEach(row => {
      const prayerName = (row as HTMLElement).dataset.prayer;
      if (prayerName === nextPrayer.name) {
        row.classList.add('next-prayer-highlight');
      }
    });
  }

  function updateLanguage(lang: string) {
    currentLang = lang;
    if (!prayerData) return;

    const translations = {
      title: { en: 'Prayer Times', ar: 'أوقات الصلاة' },
      schedule_label: { en: "Today's Schedule", ar: 'جدول اليوم' },
    };

    const updates: Array<{ element: Element; value: string }> = [];
    const elements = document.querySelectorAll('[data-key]');
    
    elements.forEach(el => {
      const key = el.dataset.key;
      let value = '';

      switch (key) {
        case 'title':
          value = translations.title[lang];
          break;
        case 'date':
          value = prayerData.date_translated?.[lang];
          break;
        case 'current_time_label':
          value = prayerData.current_local_time_label?.[lang];
          break;
        case 'next_prayer_label':
          value = prayerData.next_prayer_label?.[lang];
          break;
        case 'next_prayer':
          value = prayerData.next_prayer?.[lang];
          break;
        case 'next_time':
          value = prayerData.next_time?.[lang];
          break;
        case 'schedule_label':
          value = translations.schedule_label[lang];
          break;
        case 'fajr_name':
          value = prayerData.prayer_schedule?.fajr?.name?.[lang];
          break;
        case 'fajr_begins':
          value = prayerData.prayer_schedule?.fajr?.begins?.[lang];
          break;
        case 'iqamah_label':
          value = prayerData.iqamah_label?.[lang];
          break;
        case 'fajr_iqamah':
          value = prayerData.prayer_schedule?.fajr?.iqamah?.[lang];
          break;
        case 'sunrise_name':
          value = prayerData.prayer_schedule?.sunrise?.name?.[lang];
          break;
        case 'sunrise_time':
          value = prayerData.prayer_schedule?.sunrise?.time?.[lang];
          break;
        case 'dhuhr_name':
          value = prayerData.prayer_schedule?.dhuhr?.name?.[lang];
          break;
        case 'dhuhr_begins':
          value = prayerData.prayer_schedule?.dhuhr?.begins?.[lang];
          break;
        case 'dhuhr_iqamah':
          value = prayerData.prayer_schedule?.dhuhr?.iqamah?.[lang];
          break;
        case 'asr_name':
          value = prayerData.prayer_schedule?.asr?.name?.[lang];
          break;
        case 'asr_begins':
          value = prayerData.prayer_schedule?.asr?.begins?.[lang];
          break;
        case 'asr_iqamah':
          value = prayerData.prayer_schedule?.asr?.iqamah?.[lang];
          break;
        case 'maghrib_name':
          value = prayerData.prayer_schedule?.maghrib?.name?.[lang];
          break;
        case 'maghrib_begins':
          value = prayerData.prayer_schedule?.maghrib?.begins?.[lang];
          break;
        case 'maghrib_iqamah':
          value = prayerData.prayer_schedule?.maghrib?.iqamah?.[lang];
          break;
        case 'isha_name':
          value = prayerData.prayer_schedule?.isha?.name?.[lang];
          break;
        case 'isha_begins':
          value = prayerData.prayer_schedule?.isha?.begins?.[lang];
          break;
        case 'isha_iqamah':
          value = prayerData.prayer_schedule?.isha?.iqamah?.[lang];
          break;
      }

      if (value) {
        updates.push({ element: el, value });
      }
    });

    requestAnimationFrame(() => {
      updates.forEach(update => {
        update.element.textContent = update.value;
      });
      
      const prayerTimesDiv = document.querySelector('.prayer-times') as HTMLElement;
      if (prayerTimesDiv) {
        prayerTimesDiv.dir = lang === 'ar' ? 'rtl' : 'ltr';
      }
      
      updateClock();
    });
  }

  function handleLanguageChange(e: Event) {
    if ((e.target as HTMLInputElement).name === 'language') {
      updateLanguage((e.target as HTMLInputElement).value);
    }
  }

  function scheduleMidnightRefresh() {
    const now = new Date();
    const midnight = new Date(now);
    midnight.setHours(24, 0, 0, 0);
    const msUntilMidnight = midnight.getTime() - now.getTime();
    
    setTimeout(() => {
      fetchPrayerTimesData();
      scheduleMidnightRefresh();
    }, msUntilMidnight);
  }

  document.addEventListener('DOMContentLoaded', () => {
    fetchPrayerTimesData();
    updateClock();
    setInterval(updateClock, 1000);
    setInterval(updateNextPrayerIcon, 60000);
    scheduleMidnightRefresh();

    const languageInputs = document.querySelectorAll('input[name="language"]');
    languageInputs.forEach(input => {
      input.addEventListener('change', handleLanguageChange);
    });
  });
</script>
