</style>

<script>
  let currentLang = 'en';
  let prayerData: any = null;

  async function fetchPrayerTimesData() {
    try {
      const API_KEY = import.meta.env.FIVEPRAYER_API_KEY || import.meta.env.PUBLIC_FIVEPRAYER_API_KEY;
      const API_BASE = 'https://fiveprayer.com/wp-json/fiveprayer/v1/external';
      const url = `${API_BASE}/next-prayer?langs=en,ar&time_format=12h`;
      
      const response = await fetch(url, {
        headers: {
          'X-API-Key': API_KEY,
        },
      });
      
      if (!response.ok) throw new Error('Failed to fetch prayer times');
      const data = await response.json();
      prayerData = data;
      displayPrayerTimes(data);
      return data;
    } catch (error) {
      showError(error instanceof Error ? error.message : 'Failed to load prayer times');
      return null;
    }
  }

  function displayPrayerTimes(data: any) {
    const errorContainer = document.getElementById('error-container');
    const prayerTimesDiv = document.getElementById('prayer-times') as HTMLElement;

    if (errorContainer) errorContainer.style.display = 'none';
    if (prayerTimesDiv) {
      prayerTimesDiv.style.display = 'block';
      prayerTimesDiv.dataset.prayerData = JSON.stringify(data);
    }

    // Update all data-key elements
    const elements = document.querySelectorAll('[data-key]');
    elements.forEach(el => {
      const key = el.dataset.key;
      let value = '';

      switch (key) {
        case 'title':
          value = 'Prayer Times';
          break;
        case 'date':
          value = data.date_translated?.en || '';
          break;
        case 'current_time_label':
          value = data.current_local_time_label?.en || '';
          break;
        case 'next_prayer_label':
          value = data.next_prayer_label?.en || '';
          break;
        case 'next_prayer':
          value = data.next_prayer?.en || '';
          break;
        case 'next_time':
          value = data.next_time?.en || '';
          break;
        case 'schedule_label':
          value = "Today's Schedule";
          break;
        case 'fajr_name':
          value = data.prayer_schedule?.fajr?.name?.en || '';
          break;
        case 'fajr_begins':
          value = data.prayer_schedule?.fajr?.begins?.en || '';
          break;
        case 'iqamah_label':
          value = data.iqamah_label?.en || '';
          break;
        case 'fajr_iqamah':
          value = data.prayer_schedule?.fajr?.iqamah?.en || '';
          break;
        case 'sunrise_name':
          value = data.prayer_schedule?.sunrise?.name?.en || '';
          break;
        case 'sunrise_time':
          value = data.prayer_schedule?.sunrise?.time?.en || '';
          break;
        case 'dhuhr_name':
          value = data.prayer_schedule?.dhuhr?.name?.en || '';
          break;
        case 'dhuhr_begins':
          value = data.prayer_schedule?.dhuhr?.begins?.en || '';
          break;
        case 'dhuhr_iqamah':
          value = data.prayer_schedule?.dhuhr?.iqamah?.en || '';
          break;
        case 'asr_name':
          value = data.prayer_schedule?.asr?.name?.en || '';
          break;
        case 'asr_begins':
          value = data.prayer_schedule?.asr?.begins?.en || '';
          break;
        case 'asr_iqamah':
          value = data.prayer_schedule?.asr?.iqamah?.en || '';
          break;
        case 'maghrib_name':
          value = data.prayer_schedule?.maghrib?.name?.en || '';
          break;
        case 'maghrib_begins':
          value = data.prayer_schedule?.maghrib?.begins?.en || '';
          break;
        case 'maghrib_iqamah':
          value = data.prayer_schedule?.maghrib?.iqamah?.en || '';
          break;
        case 'isha_name':
          value = data.prayer_schedule?.isha?.name?.en || '';
          break;
        case 'isha_begins':
          value = data.prayer_schedule?.isha?.begins?.en || '';
          break;
        case 'isha_iqamah':
          value = data.prayer_schedule?.isha?.iqamah?.en || '';
          break;
      }

      if (value) {
        el.textContent = value;
      }
    });

    // Update timezone
    const timezoneEl = document.getElementById('timezone');
    if (timezoneEl) {
      timezoneEl.textContent = `Timezone: ${data.timezone || ''}`;
    }

    updateNextPrayerIcon();
  }

  function showError(message: string) {
    const errorContainer = document.getElementById('error-container');
    const errorMessageEl = document.getElementById('error-message');
    const prayerTimesDiv = document.getElementById('prayer-times');

    if (errorContainer) errorContainer.style.display = 'block';
    if (errorMessageEl) errorMessageEl.textContent = message;
    if (prayerTimesDiv) prayerTimesDiv.style.display = 'none';
  }

  function scheduleMidnightRefresh() {
    const now = new Date();
    const midnight = new Date(now);
    midnight.setHours(24, 0, 0, 0);
    const msUntilMidnight = midnight.getTime() - now.getTime();
    
    setTimeout(() => {
      fetchPrayerTimesData();
      scheduleMidnightRefresh();
    }, msUntilMidnight);
  }

  function shouldFetchNewData(): boolean {
    if (!prayerData) return true;
    
    const now = new Date();
    const currentMinutes = now.getHours() * 60 + now.getMinutes();
    
    // Check each prayer's iqamah time
    const prayers = ['fajr', 'dhuhr', 'asr', 'maghrib', 'isha'];
    for (const prayer of prayers) {
      const iqamahTime = prayerData.prayer_schedule?.[prayer]?.iqamah?.en;
      if (iqamahTime) {
        const iqamahMinutes = parseTime(iqamahTime);
        // If current time just passed iqamah time (within the last minute)
        if (currentMinutes >= iqamahMinutes && currentMinutes < iqamahMinutes + 1) {
          return true;
        }
      }
    }
    
    return false;
  }

  function schedulePeriodicFetch() {
    // Check every minute if we should fetch new data
    setInterval(() => {
      if (shouldFetchNewData()) {
        fetchPrayerTimesData();
      }
    }, 60000);
  }

  function updateClock() {
    const clockElement = document.getElementById('live-clock');
    if (clockElement) {
      const now = new Date();
      const hours = now.getHours();
      const minutes = now.getMinutes().toString().padStart(2, '0');
      const seconds = now.getSeconds().toString().padStart(2, '0');
      const ampm = hours >= 12 ? 'PM' : 'AM';
      const displayHours = hours % 12 || 12;
      
      if (currentLang === 'ar') {
        const toArabicNumeral = (n: string) => {
          const arabicNumerals = ['٠', '١', '٢', '٣', '٤', '٥', '٦', '٧', '٨', '٩'];
          return n.replace(/\d/g, (d) => arabicNumerals[parseInt(d)]);
        };
        const arabicAmpm = hours >= 12 ? 'م' : 'ص';
        clockElement.textContent = `${toArabicNumeral(displayHours.toString())}:${toArabicNumeral(minutes)}:${toArabicNumeral(seconds)} ${arabicAmpm}`;
      } else {
        clockElement.textContent = `${displayHours}:${minutes}:${seconds} ${ampm}`;
      }
    }
  }

  function parseTime(timeStr: string): number {
    // Handle 12-hour format with AM/PM
    const isPM = timeStr.toLowerCase().includes('pm');
    const isAM = timeStr.toLowerCase().includes('am');
    
    // Remove AM/PM and any spaces
    const cleanTime = timeStr.replace(/(am|pm|AM|PM|\s)/g, '');
    const [hours, minutes] = cleanTime.split(':').map(Number);
    
    let hours24 = hours;
    if (isPM && hours !== 12) {
      hours24 = hours + 12;
    } else if (isAM && hours === 12) {
      hours24 = 0;
    }
    
    return hours24 * 60 + minutes;
  }

  function getNextPrayer(data: any): { name: string; time: string; icon: string } | null {
    const now = new Date();
    const currentMinutes = now.getHours() * 60 + now.getMinutes();
    
    const prayers = [
      { name: 'fajr', time: data.prayer_schedule?.fajr?.begins?.en, icon: '🌙' },
      { name: 'sunrise', time: data.prayer_schedule?.sunrise?.time?.en, icon: '🌅' },
      { name: 'dhuhr', time: data.prayer_schedule?.dhuhr?.begins?.en, icon: '☀️' },
      { name: 'asr', time: data.prayer_schedule?.asr?.begins?.en, icon: '🌤️' },
      { name: 'maghrib', time: data.prayer_schedule?.maghrib?.begins?.en, icon: '🌇' },
      { name: 'isha', time: data.prayer_schedule?.isha?.begins?.en, icon: '🌃' }
    ];

    for (const prayer of prayers) {
      if (prayer.time) {
        const prayerMinutes = parseTime(prayer.time);
        if (prayerMinutes > currentMinutes) {
          return prayer;
        }
      }
    }

    return prayers[0];
  }

  function updateNextPrayerIcon() {
    if (!prayerData) return;

    const nextPrayer = getNextPrayer(prayerData);
    if (!nextPrayer) return;

    const nextPrayerIcon = document.getElementById('next-prayer-icon');
    if (nextPrayerIcon) {
      nextPrayerIcon.textContent = nextPrayer.icon;
    }

    const nextPrayerNameEl = document.querySelector('[data-key="next_prayer"]');
    const nextPrayerTimeEl = document.querySelector('[data-key="next_time"]');
    
    if (nextPrayerNameEl) {
      nextPrayerNameEl.textContent = prayerData.next_prayer?.[currentLang as 'en' | 'ar'] || nextPrayer.name;
    }
    
    if (nextPrayerTimeEl) {
      nextPrayerTimeEl.textContent = prayerData.next_time?.[currentLang as 'en' | 'ar'] || nextPrayer.time;
    }

    document.querySelectorAll('.prayer-row').forEach(row => {
      row.classList.remove('next-prayer-highlight');
    });

    const prayerRows = document.querySelectorAll('.prayer-row[data-prayer]');
    prayerRows.forEach(row => {
      const prayerName = (row as HTMLElement).dataset.prayer;
      if (prayerName === nextPrayer.name) {
        row.classList.add('next-prayer-highlight');
      }
    });
  }

  function updateLanguage(lang: string) {
    currentLang = lang;
    if (!prayerData) return;

    const translations = {
      title: { en: 'Prayer Times', ar: 'أوقات الصلاة' },
      schedule_label: { en: "Today's Schedule", ar: 'جدول اليوم' },
    };

    const updates: Array<{ element: Element; value: string }> = [];
    const elements = document.querySelectorAll('[data-key]');
    
    elements.forEach(el => {
      const key = el.dataset.key;
      let value = '';

      switch (key) {
        case 'title':
          value = translations.title[lang as 'en' | 'ar'];
          break;
        case 'date':
          value = prayerData.date_translated?.[lang as 'en' | 'ar'];
          break;
        case 'current_time_label':
          value = prayerData.current_local_time_label?.[lang as 'en' | 'ar'];
          break;
        case 'next_prayer_label':
          value = prayerData.next_prayer_label?.[lang as 'en' | 'ar'];
          break;
        case 'next_prayer':
          value = prayerData.next_prayer?.[lang as 'en' | 'ar'];
          break;
        case 'next_time':
          value = prayerData.next_time?.[lang as 'en' | 'ar'];
          break;
        case 'schedule_label':
          value = translations.schedule_label[lang as 'en' | 'ar'];
          break;
        case 'fajr_name':
          value = prayerData.prayer_schedule?.fajr?.name?.[lang as 'en' | 'ar'];
          break;
        case 'fajr_begins':
          value = prayerData.prayer_schedule?.fajr?.begins?.[lang as 'en' | 'ar'];
          break;
        case 'iqamah_label':
          value = prayerData.iqamah_label?.[lang as 'en' | 'ar'];
          break;
        case 'fajr_iqamah':
          value = prayerData.prayer_schedule?.fajr?.iqamah?.[lang as 'en' | 'ar'];
          break;
        case 'sunrise_name':
          value = prayerData.prayer_schedule?.sunrise?.name?.[lang as 'en' | 'ar'];
          break;
        case 'sunrise_time':
          value = prayerData.prayer_schedule?.sunrise?.time?.[lang as 'en' | 'ar'];
          break;
        case 'dhuhr_name':
          value = prayerData.prayer_schedule?.dhuhr?.name?.[lang as 'en' | 'ar'];
          break;
        case 'dhuhr_begins':
          value = prayerData.prayer_schedule?.dhuhr?.begins?.[lang as 'en' | 'ar'];
          break;
        case 'dhuhr_iqamah':
          value = prayerData.prayer_schedule?.dhuhr?.iqamah?.[lang as 'en' | 'ar'];
          break;
        case 'asr_name':
          value = prayerData.prayer_schedule?.asr?.name?.[lang as 'en' | 'ar'];
          break;
        case 'asr_begins':
          value = prayerData.prayer_schedule?.asr?.begins?.[lang as 'en' | 'ar'];
          break;
        case 'asr_iqamah':
          value = prayerData.prayer_schedule?.asr?.iqamah?.[lang as 'en' | 'ar'];
          break;
        case 'maghrib_name':
          value = prayerData.prayer_schedule?.maghrib?.name?.[lang as 'en' | 'ar'];
          break;
        case 'maghrib_begins':
          value = prayerData.prayer_schedule?.maghrib?.begins?.[lang as 'en' | 'ar'];
          break;
        case 'maghrib_iqamah':
          value = prayerData.prayer_schedule?.maghrib?.iqamah?.[lang as 'en' | 'ar'];
          break;
        case 'isha_name':
          value = prayerData.prayer_schedule?.isha?.name?.[lang as 'en' | 'ar'];
          break;
        case 'isha_begins':
          value = prayerData.prayer_schedule?.isha?.begins?.[lang as 'en' | 'ar'];
          break;
        case 'isha_iqamah':
          value = prayerData.prayer_schedule?.isha?.iqamah?.[lang as 'en' | 'ar'];
          break;
      }

      if (value) {
        updates.push({ element: el, value });
      }
    });

    requestAnimationFrame(() => {
      updates.forEach(update => {
        update.element.textContent = update.value;
      });
      
      // Update RTL for Arabic
      if (lang === 'ar') {
        document.body.dir = 'rtl';
      } else {
        document.body.dir = 'ltr';
      }

      // Update next prayer header with new language
      updateNextPrayerIcon();
    });
  }

  function handleLanguageChange(e: Event) {
    if ((e.target as HTMLInputElement).name === 'language') {
      updateLanguage((e.target as HTMLInputElement).value);
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Try to use server-side data first, fallback to client-side fetch
    const prayerTimesDiv = document.querySelector('.prayer-times') as HTMLElement;
    if (prayerTimesDiv && prayerTimesDiv.dataset.prayerData) {
      prayerData = JSON.parse(prayerTimesDiv.dataset.prayerData);
    } else {
      // If no server-side data, fetch from API
      fetchPrayerTimesData();
    }
    
    updateClock();
    setInterval(updateClock, 1000);
    updateNextPrayerIcon();
    
    // Fetch prayer times every minute to update next prayer dynamically
    schedulePeriodicFetch();
    
    // Schedule midnight refresh for Vercel/Netlify
    scheduleMidnightRefresh();

    const languageInputs = document.querySelectorAll('input[name="language"]');
    languageInputs.forEach(input => {
      input.addEventListener('change', handleLanguageChange);
    });
  });
</script>
