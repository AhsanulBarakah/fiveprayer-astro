    color: white;
    position: relative;
  }

  .next-prayer-icon {
    position: absolute;
    top: 0;
    right: 0.5rem;
    font-size: 1.25rem;
  }

  .next-prayer h2 {
    margin: 0 0 0.25rem 0;
    font-size: 0.75rem;
    opacity: 0.9;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .next-prayer-info {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
  }

  .next-prayer .prayer-name {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .next-prayer .prayer-time {
    font-size: 1.1rem;
    font-weight: 600;
  }

  .prayer-schedule h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1rem;
    color: #1a1a1a;
  }

  .prayer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem;
    background: #f9f9f9;
    border-radius: 8px;
    margin-bottom: 0.375rem;
    transition: all 0.2s;
    gap: 0.375rem;
  }

  .prayer-row:hover {
    background: #f0f0f0;
  }

  .prayer-row.sunrise {
