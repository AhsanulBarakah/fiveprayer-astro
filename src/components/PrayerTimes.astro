---
import { fetchPrayerTimes, type PrayerTimesResponse } from '../lib/api';

let prayerTimes: PrayerTimesResponse | null = null;
let error: string | null = null;

try {
  prayerTimes = await fetchPrayerTimes();
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load prayer times';
}
---

<div class="prayer-times-container">
  <div class="error-container" id="error-container" style="display: none;">
    <div class="error-icon">⚠️</div>
    <h3 class="error-title">Unable to Load Prayer Times</h3>
    <p class="error-message" id="error-message"></p>
    <p class="error-hint">Please check your API key configuration and try again.</p>
  </div>

  {prayerTimes && (
    <div class="prayer-times" id="prayer-times" data-prayer-data={JSON.stringify(prayerTimes)} style="display: block;">
    <div class="language-switcher">
      <label>
        <input type="radio" name="language" value="en" checked />
        <span>English</span>
      </label>
      <label>
        <input type="radio" name="language" value="ar" />
        <span>العربية</span>
      </label>
    </div>

    <div class="header">
      <h1 data-key="title">Prayer Times</h1>
      <p class="date" data-key="date">{prayerTimes.date_translated.en}</p>
      <p class="current-time">
        <span data-key="current_time_label">{prayerTimes.current_local_time_label.en}</span>: <span id="live-clock">{prayerTimes.current_time.en}</span>
      </p>
    </div>

    <div class="next-prayer">
      <span class="next-prayer-icon" id="next-prayer-icon">🌙</span>
      <h2 data-key="next_prayer_label">{prayerTimes.next_prayer_label.en}</h2>
      <div class="next-prayer-info">
        <div class="next-prayer-details">
          <span class="prayer-name" data-key="next_prayer">{prayerTimes.next_prayer.en}</span>
          <span class="prayer-time" data-key="next_time">{prayerTimes.next_time.en}</span>
        </div>
      </div>
    </div>

    <div class="prayer-schedule">
      <h3 data-key="schedule_label">Today's Schedule</h3>
      
      <div class="prayer-row" data-prayer="fajr">
        <span class="prayer-icon">🌙</span>
        <span class="prayer-name" data-key="fajr_name">{prayerTimes.prayer_schedule.fajr.name.en}</span>
        <span class="prayer-time">
          <span data-key="fajr_begins">{prayerTimes.prayer_schedule.fajr.begins.en}</span>
          <span class="iqamah"><span data-key="iqamah_label">{prayerTimes.iqamah_label.en}</span>: <span data-key="fajr_iqamah">{prayerTimes.prayer_schedule.fajr.iqamah?.en}</span></span>
        </span>
      </div>

      <div class="prayer-row sunrise" data-prayer="sunrise">
        <span class="prayer-icon">🌅</span>
        <span class="prayer-name" data-key="sunrise_name">{prayerTimes.prayer_schedule.sunrise.name?.en}</span>
        <span class="prayer-time" data-key="sunrise_time">{prayerTimes.prayer_schedule.sunrise.time?.en}</span>
      </div>

      <div class="prayer-row" data-prayer="dhuhr">
        <span class="prayer-icon">☀️</span>
        <span class="prayer-name" data-key="dhuhr_name">{prayerTimes.prayer_schedule.dhuhr.name.en}</span>
        <span class="prayer-time">
          <span data-key="dhuhr_begins">{prayerTimes.prayer_schedule.dhuhr.begins.en}</span>
          <span class="iqamah"><span data-key="iqamah_label">{prayerTimes.iqamah_label.en}</span>: <span data-key="dhuhr_iqamah">{prayerTimes.prayer_schedule.dhuhr.iqamah?.en}</span></span>
        </span>
      </div>

      <div class="prayer-row" data-prayer="asr">
        <span class="prayer-icon">🌤️</span>
        <span class="prayer-name" data-key="asr_name">{prayerTimes.prayer_schedule.asr.name.en}</span>
        <span class="prayer-time">
          <span data-key="asr_begins">{prayerTimes.prayer_schedule.asr.begins.en}</span>
          <span class="iqamah"><span data-key="iqamah_label">{prayerTimes.iqamah_label.en}</span>: <span data-key="asr_iqamah">{prayerTimes.prayer_schedule.asr.iqamah?.en}</span></span>
        </span>
      </div>

      <div class="prayer-row" data-prayer="maghrib">
        <span class="prayer-icon">🌇</span>
        <span class="prayer-name" data-key="maghrib_name">{prayerTimes.prayer_schedule.maghrib.name.en}</span>
        <span class="prayer-time">
          <span data-key="maghrib_begins">{prayerTimes.prayer_schedule.maghrib.begins.en}</span>
          <span class="iqamah"><span data-key="iqamah_label">{prayerTimes.iqamah_label.en}</span>: <span data-key="maghrib_iqamah">{prayerTimes.prayer_schedule.maghrib.iqamah?.en}</span></span>
        </span>
      </div>

      <div class="prayer-row" data-prayer="isha">
        <span class="prayer-icon">🌃</span>
        <span class="prayer-name" data-key="isha_name">{prayerTimes.prayer_schedule.isha.name.en}</span>
        <span class="prayer-time">
          <span data-key="isha_begins">{prayerTimes.prayer_schedule.isha.begins.en}</span>
          <span class="iqamah"><span data-key="iqamah_label">{prayerTimes.iqamah_label.en}</span>: <span data-key="isha_iqamah">{prayerTimes.prayer_schedule.isha.iqamah?.en}</span></span>
        </span>
      </div>
    </div>

    <p class="timezone">Timezone: {prayerTimes.timezone}</p>
    <p class="disclaimer">Please follow your local masjid prayer times. Data provided by fiveprayer API, built with Astro.</p>
  </div>
  )}
</div>

<style>
  .prayer-times-container {
    max-width: 500px;
    margin: 0 auto;
    padding: 0.5rem;
    font-family: system-ui, -apple-system, sans-serif;
  }

  .loading {
    text-align: center;
    padding: 2rem;
    font-size: 1.1rem;
    color: #666;
  }

  .error-container {
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 15px;
    padding: 2rem;
    text-align: center;
    box-shadow: 0 4px 15px rgba(220, 38, 38, 0.1);
  }

  .error-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .error-title {
    margin: 0 0 0.75rem 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: #dc2626;
  }

  .error-message {
    margin: 0 0 0.5rem 0;
    font-size: 0.95rem;
    color: #991b1b;
  }

  .error-hint {
    margin: 0;
    font-size: 0.85rem;
    color: #7f1d1d;
  }

  .prayer-times {
    background: white;
    border-radius: 15px;
    padding: 0.75rem;
    color: #1a1a1a;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
    border: 1px solid #e5e5e5;
  }

  .language-switcher {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    width: 100%;
  }

  .language-switcher label {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    cursor: pointer;
    font-size: 0.85rem;
    padding: 0.25rem 0.75rem;
    background: #f5f5f5;
    border-radius: 15px;
    transition: background 0.2s;
    color: #1a1a1a;
    width: 100px;
    justify-content: center;
  }

  .language-switcher label:hover {
    background: #e5e5e5;
  }

  .language-switcher input[type="radio"] {
    cursor: pointer;
    accent-color: #10b981;
    margin: 0;
  }

  .header {
    text-align: center;
    margin-bottom: 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #e5e5e5;
  }

  .header h1 {
    margin: 0 0 0.125rem 0;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .date {
    margin: 0.125rem 0 0.75rem 0;
    font-size: 0.9rem;
    color: #666;
  }

  .current-time {
    margin: 0;
    font-size: 0.8rem;
    color: #888;
