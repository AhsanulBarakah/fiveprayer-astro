---
import { fetchPrayerTimes, type PrayerTimesResponse } from '../lib/api';

let prayerTimes: PrayerTimesResponse | null = null;
let error: string | null = null;
let loading = true;

try {
  prayerTimes = await fetchPrayerTimes();
  loading = false;
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load prayer times';
  loading = false;
}
---

<div class="prayer-times-container">
  {loading && <p class="loading">Loading prayer times...</p>}

  {error && (
    <div class="error-container">
      <div class="error-icon">⚠️</div>
      <h3 class="error-title">Unable to Load Prayer Times</h3>
      <p class="error-message">{error}</p>
      <p class="error-hint">Please check your API key configuration and try again.</p>
    </div>
  )}

  {prayerTimes && (
    <div class="prayer-times" data-prayer-data={JSON.stringify(prayerTimes)}>
      <div class="language-switcher">
        <label>
          <input type="radio" name="language" value="en" checked />
          <span>English</span>
        </label>
        <label>
          <input type="radio" name="language" value="ar" />
          <span>العربية</span>
        </label>
      </div>

      <div class="header">
        <h1 data-key="title">Prayer Times</h1>
        <p class="date" data-key="date">{prayerTimes.date_translated.en}</p>
        <p class="current-time">
          <span data-key="current_time_label">{prayerTimes.current_local_time_label.en}</span>: <span id="live-clock">{prayerTimes.current_time.en}</span>
        </p>
      </div>

      <div class="next-prayer">
        <span class="next-prayer-icon" id="next-prayer-icon">🌙</span>
        <h2 data-key="next_prayer_label">{prayerTimes.next_prayer_label.en}</h2>
        <div class="next-prayer-info">
          <div class="next-prayer-details">
            <span class="prayer-name" data-key="next_prayer">{prayerTimes.next_prayer.en}</span>
            <span class="prayer-time" data-key="next_time">{prayerTimes.next_time.en}</span>
          </div>
        </div>
      </div>

      <div class="prayer-schedule">
        <h3 data-key="schedule_label">Today's Schedule</h3>
        
        <div class="prayer-row" data-prayer="fajr">
          <span class="prayer-icon">🌙</span>
          <span class="prayer-name" data-key="fajr_name">{prayerTimes.prayer_schedule.fajr.name.en}</span>
          <span class="prayer-time">
            <span data-key="fajr_begins">{prayerTimes.prayer_schedule.fajr.begins.en}</span>
            <span class="iqamah"><span data-key="iqamah_label">{prayerTimes.iqamah_label.en}</span>: <span data-key="fajr_iqamah">{prayerTimes.prayer_schedule.fajr.iqamah?.en}</span></span>
          </span>
        </div>

        <div class="prayer-row sunrise" data-prayer="sunrise">
          <span class="prayer-icon">🌅</span>
          <span class="prayer-name" data-key="sunrise_name">{prayerTimes.prayer_schedule.sunrise.name?.en}</span>
          <span class="prayer-time" data-key="sunrise_time">{prayerTimes.prayer_schedule.sunrise.time?.en}</span>
        </div>

        <div class="prayer-row" data-prayer="dhuhr">
          <span class="prayer-icon">☀️</span>
          <span class="prayer-name" data-key="dhuhr_name">{prayerTimes.prayer_schedule.dhuhr.name.en}</span>
          <span class="prayer-time">
            <span data-key="dhuhr_begins">{prayerTimes.prayer_schedule.dhuhr.begins.en}</span>
            <span class="iqamah"><span data-key="iqamah_label">{prayerTimes.iqamah_label.en}</span>: <span data-key="dhuhr_iqamah">{prayerTimes.prayer_schedule.dhuhr.iqamah?.en}</span></span>
          </span>
        </div>

        <div class="prayer-row" data-prayer="asr">
          <span class="prayer-icon">🌤️</span>
          <span class="prayer-name" data-key="asr_name">{prayerTimes.prayer_schedule.asr.name.en}</span>
          <span class="prayer-time">
            <span data-key="asr_begins">{prayerTimes.prayer_schedule.asr.begins.en}</span>
            <span class="iqamah"><span data-key="iqamah_label">{prayerTimes.iqamah_label.en}</span>: <span data-key="asr_iqamah">{prayerTimes.prayer_schedule.asr.iqamah?.en}</span></span>
          </span>
        </div>

        <div class="prayer-row" data-prayer="maghrib">
          <span class="prayer-icon">🌇</span>
          <span class="prayer-name" data-key="maghrib_name">{prayerTimes.prayer_schedule.maghrib.name.en}</span>
          <span class="prayer-time">
            <span data-key="maghrib_begins">{prayerTimes.prayer_schedule.maghrib.begins.en}</span>
            <span class="iqamah"><span data-key="iqamah_label">{prayerTimes.iqamah_label.en}</span>: <span data-key="maghrib_iqamah">{prayerTimes.prayer_schedule.maghrib.iqamah?.en}</span></span>
          </span>
        </div>

        <div class="prayer-row" data-prayer="isha">
          <span class="prayer-icon">🌃</span>
          <span class="prayer-name" data-key="isha_name">{prayerTimes.prayer_schedule.isha.name.en}</span>
          <span class="prayer-time">
            <span data-key="isha_begins">{prayerTimes.prayer_schedule.isha.begins.en}</span>
            <span class="iqamah"><span data-key="iqamah_label">{prayerTimes.iqamah_label.en}</span>: <span data-key="isha_iqamah">{prayerTimes.prayer_schedule.isha.iqamah?.en}</span></span>
          </span>
        </div>
      </div>

      <p class="timezone">Timezone: {prayerTimes.timezone}</p>
      <p class="disclaimer">Please follow your local masjid prayer times. Data provided by fiveprayer API, built with Astro.</p>
    </div>
  )}
</div>

<style>
  .prayer-times-container {
    max-width: 500px;
    margin: 0 auto;
    padding: 0.5rem;
    font-family: system-ui, -apple-system, sans-serif;
  }

  .loading {
    text-align: center;
    padding: 2rem;
    font-size: 1.1rem;
    color: #666;
  }

  .error-container {
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 15px;
    padding: 2rem;
    text-align: center;
    box-shadow: 0 4px 15px rgba(220, 38, 38, 0.1);
  }

  .error-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .error-title {
    margin: 0 0 0.75rem 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: #dc2626;
  }

  .error-message {
    margin: 0 0 0.5rem 0;
    font-size: 0.95rem;
    color: #991b1b;
  }

  .error-hint {
    margin: 0;
    font-size: 0.85rem;
    color: #7f1d1d;
  }

  .prayer-times {
    background: white;
    border-radius: 15px;
    padding: 0.75rem;
    color: #1a1a1a;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
    border: 1px solid #e5e5e5;
  }

  .language-switcher {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    width: 100%;
  }

  .language-switcher label {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    cursor: pointer;
    font-size: 0.85rem;
    padding: 0.25rem 0.75rem;
    background: #f5f5f5;
    border-radius: 15px;
    transition: background 0.2s;
    color: #1a1a1a;
    width: 100px;
    justify-content: center;
  }

  .language-switcher label:hover {
    background: #e5e5e5;
  }

  .language-switcher input[type="radio"] {
    cursor: pointer;
    accent-color: #10b981;
    margin: 0;
  }

  .header {
    text-align: center;
    margin-bottom: 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #e5e5e5;
  }

  .header h1 {
    margin: 0 0 0.125rem 0;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .date {
    margin: 0.125rem 0 0.75rem 0;
    font-size: 0.9rem;
    color: #666;
  }

  .current-time {
    margin: 0;
    font-size: 0.8rem;
    color: #888;
  }

  .current-time span {
    margin-left: -0.5rem;
  }

  #live-clock {
    font-family: 'Courier New', Courier, monospace;
    display: inline-block;
    min-width: 120px;
  }

  .next-prayer {
    background: linear-gradient(294deg, #308d07 0%, #299f02 100%);
    border-radius: 10px;
    padding: 0.75rem;
    margin-bottom: 0.75rem;
    text-align: center;
    color: white;
    position: relative;
  }

  .next-prayer-icon {
    position: absolute;
    top: 0;
    right: 0.5rem;
    font-size: 1.25rem;
  }

  .next-prayer h2 {
    margin: 0 0 0.25rem 0;
    font-size: 0.75rem;
    opacity: 0.9;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .next-prayer-info {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
  }

  .next-prayer .prayer-name {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .next-prayer .prayer-time {
    font-size: 1.1rem;
    font-weight: 600;
  }

  .prayer-schedule h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1rem;
    color: #1a1a1a;
  }

  .prayer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem;
    background: #f9f9f9;
    border-radius: 8px;
    margin-bottom: 0.375rem;
    transition: all 0.2s;
    gap: 0.375rem;
  }

  .prayer-row:hover {
    background: #f0f0f0;
  }

  .prayer-row.sunrise {
    opacity: 0.7;
  }

  .prayer-row.next-prayer-highlight {
    background: linear-gradient(135deg, #10b94d 0%, #586500 100%);
    color: white;
    transform: scale(1.02);
    box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
  }

  .prayer-row.next-prayer-highlight .prayer-name,
  .prayer-row.next-prayer-highlight .prayer-time,
  .prayer-row.next-prayer-highlight .iqamah {
    color: white;
  }

  .prayer-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .next-prayer-icon {
    font-size: 3rem;
  }

  .next-prayer-details {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .prayer-row .prayer-name {
    font-weight: 600;
    font-size: 0.9rem;
    flex: 1;
  }

  .prayer-row .prayer-time {
    font-weight: 500;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.125rem;
    color: #666;
  }

  .iqamah {
    font-size: 0.75rem;
    color: #888;
  }

  .timezone {
    text-align: center;
    margin-top: 0.5rem;
    font-size: 0.7rem;
    color: #888;
  }

  .disclaimer {
    text-align: center;
    margin-top: 0.5rem;
    font-size: 0.65rem;
    color: #999;
    line-height: 1.4;
  }

  @media (max-width: 640px) {
    .prayer-times-container {
      padding: 1rem;
    }

    .prayer-times {
      padding: 1.5rem;
    }

    .header h1 {
      font-size: 1.5rem;
    }

    .next-prayer .prayer-name,
    .next-prayer .prayer-time {
      font-size: 1.4rem;
    }

    .prayer-row {
      padding: 0.75rem;
    }
  }
</style>

<script>
  let currentLang = 'en';

  function updateClock() {
    const clockElement = document.getElementById('live-clock');
    if (clockElement) {
      const now = new Date();
      const hours = now.getHours();
      const minutes = now.getMinutes().toString().padStart(2, '0');
      const seconds = now.getSeconds().toString().padStart(2, '0');
      const ampm = hours >= 12 ? 'PM' : 'AM';
      const displayHours = hours % 12 || 12;
      
      if (currentLang === 'ar') {
        // Convert to Arabic numerals and format
        const toArabicNumeral = (n: string) => {
          const arabicNumerals = ['٠', '١', '٢', '٣', '٤', '٥', '٦', '٧', '٨', '٩'];
          return n.replace(/\d/g, (d) => arabicNumerals[parseInt(d)]);
        };
        const arabicAmpm = hours >= 12 ? 'م' : 'ص';
        clockElement.textContent = `${toArabicNumeral(displayHours.toString())}:${toArabicNumeral(minutes)}:${toArabicNumeral(seconds)} ${arabicAmpm}`;
      } else {
        clockElement.textContent = `${displayHours}:${minutes}:${seconds} ${ampm}`;
      }
    }
  }

  function updateNextPrayerIcon() {
    const prayerTimesDiv = document.querySelector('.prayer-times');
    if (!prayerTimesDiv) return;

    const data = JSON.parse(prayerTimesDiv.dataset.prayerData || '{}');
    const nextPrayerEn = data.next_prayer?.en?.toLowerCase();
    
    const iconMap = {
      fajr: '🌙',
      sunrise: '🌅',
      dhuhr: '☀️',
      asr: '🌤️',
      maghrib: '🌇',
      isha: '🌃'
    };

    const nextPrayerIcon = document.getElementById('next-prayer-icon');
    if (nextPrayerIcon && nextPrayerEn) {
      nextPrayerIcon.textContent = iconMap[nextPrayerEn] || '🌙';
    }

    // Highlight the next prayer row
    document.querySelectorAll('.prayer-row').forEach(row => {
      row.classList.remove('next-prayer-highlight');
    });

    const prayerRows = document.querySelectorAll('.prayer-row[data-prayer]');
    prayerRows.forEach(row => {
      const prayerName = row.dataset.prayer;
      if (prayerName === nextPrayerEn) {
        row.classList.add('next-prayer-highlight');
      }
    });
  }

  function updateLanguage(lang) {
    currentLang = lang;
    const prayerTimesDiv = document.querySelector('.prayer-times');
    if (!prayerTimesDiv) return;

    const data = JSON.parse(prayerTimesDiv.dataset.prayerData || '{}');
    const translations = {
      title: { en: 'Prayer Times', ar: 'أوقات الصلاة' },
      schedule_label: { en: "Today's Schedule", ar: 'جدول اليوم' },
    };

    // Collect all updates first
    const updates: Array<{ element: Element; value: string }> = [];
    
    // Update all elements with data-key attributes
    const elements = prayerTimesDiv.querySelectorAll('[data-key]');
    elements.forEach(el => {
      const key = el.dataset.key;
      let value = '';

      switch (key) {
        case 'title':
          value = translations.title[lang];
          break;
        case 'date':
          value = data.date_translated?.[lang];
          break;
        case 'current_time_label':
          value = data.current_local_time_label?.[lang];
          break;
        case 'next_prayer_label':
          value = data.next_prayer_label?.[lang];
          break;
        case 'next_prayer':
          value = data.next_prayer?.[lang];
          break;
        case 'next_time':
          value = data.next_time?.[lang];
          break;
        case 'schedule_label':
          value = translations.schedule_label[lang];
          break;
        case 'fajr_name':
          value = data.prayer_schedule?.fajr?.name?.[lang];
          break;
        case 'fajr_begins':
          value = data.prayer_schedule?.fajr?.begins?.[lang];
          break;
        case 'iqamah_label':
          value = data.iqamah_label?.[lang];
          break;
        case 'fajr_iqamah':
          value = data.prayer_schedule?.fajr?.iqamah?.[lang];
          break;
        case 'sunrise_name':
          value = data.prayer_schedule?.sunrise?.name?.[lang];
          break;
        case 'sunrise_time':
          value = data.prayer_schedule?.sunrise?.time?.[lang];
          break;
        case 'dhuhr_name':
          value = data.prayer_schedule?.dhuhr?.name?.[lang];
          break;
        case 'dhuhr_begins':
          value = data.prayer_schedule?.dhuhr?.begins?.[lang];
          break;
        case 'dhuhr_iqamah':
          value = data.prayer_schedule?.dhuhr?.iqamah?.[lang];
          break;
        case 'asr_name':
          value = data.prayer_schedule?.asr?.name?.[lang];
          break;
        case 'asr_begins':
          value = data.prayer_schedule?.asr?.begins?.[lang];
          break;
        case 'asr_iqamah':
          value = data.prayer_schedule?.asr?.iqamah?.[lang];
          break;
        case 'maghrib_name':
          value = data.prayer_schedule?.maghrib?.name?.[lang];
          break;
        case 'maghrib_begins':
          value = data.prayer_schedule?.maghrib?.begins?.[lang];
          break;
        case 'maghrib_iqamah':
          value = data.prayer_schedule?.maghrib?.iqamah?.[lang];
          break;
        case 'isha_name':
          value = data.prayer_schedule?.isha?.name?.[lang];
          break;
        case 'isha_begins':
          value = data.prayer_schedule?.isha?.begins?.[lang];
          break;
        case 'isha_iqamah':
          value = data.prayer_schedule?.isha?.iqamah?.[lang];
          break;
      }

      if (value) {
        updates.push({ element: el, value });
      }
    });

    // Apply all updates at once using requestAnimationFrame
    requestAnimationFrame(() => {
      updates.forEach(update => {
        update.element.textContent = update.value;
      });
      
      // Update text direction for Arabic
      prayerTimesDiv.dir = lang === 'ar' ? 'rtl' : 'ltr';
      
      // Update clock format immediately
      updateClock();
    });
  }

  function handleLanguageChange(e) {
    if (e.target.name === 'language') {
      updateLanguage(e.target.value);
    }
  }

  // Initialize
  document.addEventListener('DOMContentLoaded', () => {
    updateClock();
    setInterval(updateClock, 1000);
    updateNextPrayerIcon();

    // Add event listeners for language switcher
    const languageInputs = document.querySelectorAll('input[name="language"]');
    languageInputs.forEach(input => {
      input.addEventListener('change', handleLanguageChange);
    });
  });
</script>
